	"ATJ impacts" -> "BIOFUEL impacts" [label="ATJ.BIOMASS.consumption_index,ATJ.CO2_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"HEFA impacts" -> "BIOFUEL impacts" [label="HEFA.BIOMASS.consumption_index,HEFA.CO2_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"BATTERY impacts" -> "Aggregate impacts" [label="BATTERY.CO2_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"Charging impacts" -> "BATTERY impacts" [label="Charging.CO2_index,Charging.ELECTRICITY.consumption_index" color=black dir=forward fontcolor=black penwidth=1.0]
