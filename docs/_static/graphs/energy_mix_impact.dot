	"Biofuel impacts" -> "JET-A impacts" [label="Biofuel.BIOFUEL.consumption_index,Biofuel.CO2_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"Fossil impacts" -> "JET-A impacts" [label="Fossil.CO2_index,Fossil.KEROSENE.consumption_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"E-FUEL impacts" -> "Electrofuel impacts" [label="E-FUEL.CO2_index" color=black dir=forward fontcolor=black penwidth=1.0]
	"Power_to_liquid impacts" -> "E-FUEL impacts" [label="Power_to_liquid.CO2_index,Power_to_liquid.ELECTRICITY.consumption_index,Power_to_liquid.GAS-H2.consumption_index" color=black dir=forward fontcolor=black penwidth=1.0]
