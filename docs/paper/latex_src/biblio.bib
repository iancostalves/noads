@article{ortega_extensions_1979,
	title = {Extensions of the {Ostrowski}-{Reich} theorem for {SOR} iterations},
	volume = {28},
	issn = {0024-3795},
	url = {https://www.sciencedirect.com/science/article/pii/0024379579901319},
	doi = {10.1016/0024-3795(79)90131-9},
	abstract = {The Ostrowski-Reich theorem states that for a system Ax =b of linear equations with A nonsingular, if A is hermitian and if the diagonal of A is positive, then the SOR method converges for each relaxation parameter in (0,2) if and only if A is positive definite. This is actually a special case of the Householder-John theorem, which states that for A=M−N with A,M nonsingular, if A is hermitian and M∗+N is positive definite, then M−1N is a convergent matrix if and only if A is positive definite. Our purposes here are to generalize the Householder-John theorem and to provide an insight into how and why the SOR method can converge. As a result the Ostrowski-Reich theorem is extended in two directions; one is when A is hermitian but the diagonal of A is not necessarily positive, so that A is not necessarily positive definite, and the other is when A+A∗ is positive definite but A is not necessarily hermitian. In the process, several other convergence results are obtained for general splittings of A. However, no claims are made concerning the case in which the convergence results obtained here can be applied to practical situations.},
	urldate = {2025-06-13},
	journal = {Linear Algebra and its Applications},
	author = {Ortega, James M. and Plemmons, Robert J.},
	month = dec,
	year = {1979},
	pages = {177--191},
}

