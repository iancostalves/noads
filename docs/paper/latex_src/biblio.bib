@article{jasa_open-source_2018,
	title = {Open-source coupled aerostructural optimization using {Python}},
	volume = {57},
	issn = {1615-1488},
	url = {https://doi.org/10.1007/s00158-018-1912-8},
	doi = {10.1007/s00158-018-1912-8},
	abstract = {To teach multidisciplinary design optimization (MDO) to students effectively, it is useful to have accessible software that runs quickly, allowing hands-on exploration of coupled systems and optimization methods. Open-source software exists for low-fidelity aerodynamic or structural analysis, but there is no existing software for fast tightly coupled aerostructural analysis and design optimization. To address this need, we present OpenAeroStruct, an open-source low-fidelity aerostructural analysis and optimization tool developed in NASA’s OpenMDAO framework. It uses the coupled adjoint method to compute the derivatives required for efficient gradient-based optimization. OpenAeroStruct combines a vortex lattice method and 1-D finite-element analysis to model lifting surfaces, such as aircraft wings and tails, and uses the coupled-adjoint method to compute the aerostructural derivatives. We use the Breguet range equation to compute the fuel burn as a function of structural weight and aerodynamic performance. OpenAeroStruct has proved effective both as an educational tool and as a benchmark for researching new MDO methods. There is much more potential to be exploited as the research community continues to develop and use this tool.},
	language = {en},
	number = {4},
	urldate = {2025-06-18},
	journal = {Structural and Multidisciplinary Optimization},
	author = {Jasa, John P. and Hwang, John T. and Martins, Joaquim R. R. A.},
	month = apr,
	year = {2018},
	keywords = {Aerostructural design optimization, Computational Fluid Dynamics, Computational Science and Engineering, Computer-Aided Engineering (CAD, CAE) and Design, Engineering Fluid Dynamics, Mathematical and Computational Engineering Applications, Multidisciplinary design optimization, Open Source, Project-based learning, Python, Wing design},
	pages = {1815--1827},
}


@inproceedings{planes_simulation_2025,
	address = {Toulouse, France},
	title = {Simulation and analyses of {ICAO} transition scenarios using the {AeroMAPS} open-source framework},
	url = {https://hal.science/hal-04972436},
	doi = {10.60711/TSAS25.20250216.7026241092200926},
	abstract = {Given the need for the aviation sector to make the necessary transition to meet environmental challenges, many stakeholders in the ecosystem are proposing transition roadmaps. Here, we propose the use of AeroMAPS, an open-source modular framework for simulating air transport prospective scenarios, to reproduce these roadmaps. The approach is illustrated using scenarios from a report from the International Civil Aviation Organization (ICAO) in the context of its Long-Term global Aspirational Goal (LTAG). We demonstrate that AeroMAPS allows a rapid and consistent reproduction of the scenario, with, for instance, less than 5\% differences in CO2 emissions and efficiency cost, although larger differences are obtained for fuel costs due to differing assumptions (e.g. electricity). A significant advantage of using AeroMAPS is that it can be used to perform additional analyses, such as assessing non-CO2 climate and other environmental impacts, estimating abatement costs of mitigation strategies, and optimising scenarios.},
	urldate = {2025-06-20},
	booktitle = {Towards {Sustainable} {Aviation} {Summit} ({TSAS} 2025)},
	publisher = {3af-tsas},
	author = {Planès, Thomas and Salgas, Antoine and Delbecq, Scott},
	month = jan,
	year = {2025},
}

